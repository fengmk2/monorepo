{
  "name": "@zap-studio/monorepo",
  "private": true,
  "author": "Alexandre Trotel",
  "scripts": {
    "dev": "pnpm --filter docs run dev",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench --watch",
    "build": "pnpm --filter './packages/*' run build",
    "publish:check": "pnpm run format:check && pnpm run lint && pnpm run test && pnpm --filter './packages/*' run prepublishOnly",
    "react-doctor": "pnpm --filter docs run react-doctor",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --type-check .",
    "lint:fix": "oxlint --type-aware --type-check --fix .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.32.1"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f"
}

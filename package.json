{
  "name": "@zap-studio/monorepo",
  "private": true,
  "author": "Alexandre Trotel",
  "scripts": {
    "dev": "pnpm --filter docs run dev",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench --watch",
    "build": "pnpm --filter './packages/*' run build",
    "publish:check": "pnpm run format:check && pnpm run lint && pnpm run test && pnpm --filter './packages/*' run prepublishOnly",
    "react-doctor": "pnpm --filter docs run react-doctor",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --type-check .",
    "lint:fix": "oxlint --type-aware --type-check --fix .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.32.1"
  },
  "packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912"
}

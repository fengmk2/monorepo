{
  "name": "@zap-studio/validation",
  "version": "0.3.4",
  "private": false,
  "description": "Standard Schema utilities and ValidationError helpers.",
  "keywords": [
    "errors",
    "runtime validation",
    "schema",
    "standard schema",
    "typescript",
    "validation"
  ],
  "homepage": "https://www.zapstudio.dev/packages/validation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zap-studio/monorepo.git",
    "directory": "packages/validation"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./errors": "./dist/errors.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm dlx publint --strict && pnpm dlx @arethetypeswrong/cli --profile esm-only --pack .",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@standard-schema/spec": "catalog:"
  },
  "devDependencies": {
    "@zap-studio/typescript": "workspace:*",
    "arktype": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

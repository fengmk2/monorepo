{
  "name": "@zap-studio/retry",
  "version": "0.3.0",
  "private": false,
  "description": "Composable retry policies for resilient async operations.",
  "keywords": [
    "backoff",
    "exponential backoff",
    "fetch",
    "http",
    "resilience",
    "retry",
    "typescript"
  ],
  "homepage": "https://www.zapstudio.dev/packages/retry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zap-studio/monorepo.git",
    "directory": "packages/retry"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./abort": "./dist/abort.mjs",
    "./errors": "./dist/errors.mjs",
    "./exponential-backoff": "./dist/exponential-backoff.mjs",
    "./fixed-delay": "./dist/fixed-delay.mjs",
    "./result-mode": "./dist/result-mode.mjs",
    "./sleep": "./dist/sleep.mjs",
    "./throw-mode": "./dist/throw-mode.mjs",
    "./types": "./dist/types.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm dlx publint --strict && pnpm dlx @arethetypeswrong/cli attw --profile esm-only --pack .",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@types/async-retry": "catalog:",
    "@types/promise-retry": "catalog:",
    "@zap-studio/typescript": "workspace:*",
    "async-retry": "catalog:",
    "exponential-backoff": "catalog:",
    "p-retry": "catalog:",
    "promise-retry": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

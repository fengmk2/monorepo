{
  "name": "@zap-studio/fetch",
  "version": "0.5.3",
  "private": false,
  "description": "A type-safe fetch wrapper for HTTP requests with runtime schema validation.",
  "keywords": [
    "api",
    "arktype",
    "error handling",
    "fetch",
    "http",
    "request",
    "response",
    "runtime validation",
    "schema",
    "standard schema",
    "type-safe",
    "typescript",
    "valibot",
    "validation",
    "zod"
  ],
  "homepage": "https://www.zapstudio.dev/packages/fetch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zap-studio/monorepo.git",
    "directory": "packages/fetch"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./constants": "./dist/constants.mjs",
    "./errors": "./dist/errors.mjs",
    "./headers": "./dist/headers.mjs",
    "./internal": "./dist/internal.mjs",
    "./methods": "./dist/methods.mjs",
    "./request": "./dist/request.mjs",
    "./types": "./dist/types.mjs",
    "./url": "./dist/url.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "prepublishOnly": "vpx publint --strict && vpx -p @arethetypeswrong/cli attw --profile esm-only --pack .",
    "test": "vp test run",
    "test:watch": "vp test watch"
  },
  "dependencies": {
    "@zap-studio/validation": "workspace:*"
  },
  "devDependencies": {
    "@zap-studio/typescript": "workspace:*",
    "arktype": "catalog:",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "vite-plus": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

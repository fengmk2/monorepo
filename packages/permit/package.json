{
  "name": "@zap-studio/permit",
  "version": "0.3.2",
  "private": false,
  "description": "A type-safe, declarative authorization library for TypeScript with Standard Schema support",
  "keywords": [
    "abac",
    "access-control",
    "arktype",
    "authorization",
    "permissions",
    "policy",
    "rbac",
    "standard-schema",
    "typescript",
    "valibot",
    "zod"
  ],
  "homepage": "https://www.zapstudio.dev/packages/permit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zap-studio/monorepo.git",
    "directory": "packages/permit"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./errors": "./dist/errors.mjs",
    "./helpers": "./dist/helpers.mjs",
    "./types": "./dist/types.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm dlx publint --strict && pnpm dlx @arethetypeswrong/cli --profile esm-only --pack .",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@zap-studio/validation": "workspace:*"
  },
  "devDependencies": {
    "@zap-studio/typescript": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
